{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "x", "y", "label", "content"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Identifiant unique du POI"
      },
      "x": {
        "type": "number",
        "description": "Position X en pixels sur la carte"
      },
      "y": {
        "type": "number",
        "description": "Position Y en pixels sur la carte"
      },
      "label": {
        "type": "string",
        "description": "Libellé affiché pour le POI"
      },
      "content": {
        "type": "string",
        "description": "Chemin vers le fichier Markdown du POI (ex: assets/poi/mon-projet.md)"
      }
    },
    "additionalProperties": false
  }
}
